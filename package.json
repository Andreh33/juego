{
  "name": "umbral",
  "version": "0.0.0",
  "private": true,
  "description": "UMBRAL — roguelike deckbuilder de puntuacion (poker). Monorepo.",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "turbo": "^2",
    "typescript": "^5",
    "vitest": "^3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
